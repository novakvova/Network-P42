<Window x:Class="_3.WpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_3.WpfClient"
        mc:Ignorable="d"
Title="Chat" Height="354" MinWidth="670" Width="700" FontSize="16pt" Closing="Window_Closing">
    <Window.Background>
        <ImageBrush ImageSource="https://png.pngtree.com/thumb_back/fh260/background/20200714/pngtree-modern-double-color-futuristic-neon-background-image_351866.jpg" Stretch="Uniform"></ImageBrush>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="HotPink"></Setter>
            <Setter Property="BorderBrush" Value="Purple"></Setter>
            <Setter Property="BorderThickness" Value="3"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="FontSize" Value="23"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Content="Повідомлення" 
               Grid.ColumnSpan="2"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Foreground="LightCoral"/>

        <TextBox Name="txtText" 
                 Text="Привіт!" 
                 HorizontalAlignment="Center" 
                 TextWrapping="NoWrap"
                 Grid.Column="0"
                 Grid.Row="1"
                 MaxHeight="50"
                 Grid.ColumnSpan="2"
                 VerticalAlignment="Top"
                 MinWidth="300"
                 MaxWidth="400"
                 >
        </TextBox>

        <Button Content="Надіслати" 
                Name="btnSend" 
                Grid.Column="2"
                HorizontalAlignment="Center"  
                VerticalAlignment="Center"
                Grid.RowSpan="2"
                RenderTransformOrigin="-0.261,0.222" 
                Height="40" 
                Width="128" 
                IsEnabled="False" 
                Click="btnSend_Click" />

        <ListBox Name="lbInfo" 
                 Grid.Row="1"
                 Grid.Column="0"
                 HorizontalAlignment="Stretch" 
                 Margin="25 45"
                 Grid.ColumnSpan="2"
                 Grid.RowSpan="3"
                 MinWidth="400"
                 />

        <Button x:Name="btnPhotoSelect" 
                Width="130" Height="40" 
                Grid.Column="2"
                Grid.Row="1"
                FontSize="13"
                Click="btnPhotoSelect_Click">Вибрати фото...</Button>

        <Label Content="Ім'я" 
               HorizontalAlignment="Center" 
               Grid.Column="2"
               Grid.Row="1"
               Grid.RowSpan="2"
               VerticalAlignment="Center" 
               Foreground="DeepSkyBlue"
               FontWeight="Bold"
               FontSize="25"/>


        <TextBox Name="txtUserName"
                 HorizontalAlignment="center"                  
                 Text="Вова" 
                 TextWrapping="Wrap" 
                 Grid.Column="2"
                 VerticalAlignment="Center" 
                 Grid.Row="2"
                 MinWidth="160"/>
        <Button Name="btnConnect" 
                Content="Connect" 
                Grid.Column="2"
                Grid.Row="3"
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Height="46" 
                Width="128"
                Click="btnConnect_Click"/>
    </Grid>
</Window>
